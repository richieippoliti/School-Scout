{
  "name": "4300-flask-react-typescript-template",
  "version": "1.0.0",
  "description": "Flask + React + TypeScript Template for CS/INFO 4300",
  "scripts": {
    "install-all": "pip install -r requirements.txt && cd frontend && npm install",
    "dev": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "start": "python src/app.py"
  },
  "keywords": [
    "flask",
    "react",
    "template"
  ],
  "dependencies": {
    "leaflet": "^1.9.4",
    "react-leaflet": "^5.0.0",
    "react-leaflet-markercluster": "^5.0.0-rc.0"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7"
  }
}
